# Database Configuration
DB_URL=postgresql://nlq_readonly:changeme@localhost/olist
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT=5000

# Admin/superuser connection used ONLY by migrate.py (needs CREATE + CREATEROLE).
# The running app never uses this. Example: postgresql://postgres:pass@localhost/olist
MIGRATION_DB_URL=postgresql://localhost/olist

# DashScope Configuration (cloud LLM — qwen3.7-plus)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen3.7-plus
# Deployed fine-tuned model ID from DashScope Model Studio (after SFT job).
DASHSCOPE_FINETUNE_MODEL=
# When true, inference uses DASHSCOPE_FINETUNE_MODEL instead of DASHSCOPE_MODEL.
USE_FINETUNED_MODEL=false
# Thinking mode is incompatible with JSON structured output for tool calls.
DASHSCOPE_ENABLE_THINKING=false

# Meta-tool layer: LLM picks count/lookup shapes; backend routes to internal SQL.
# Reduces routing errors (e.g. catalog products vs orders sold). Recommended for dev.
META_TOOLS_ENABLED=true

# Phase 4 — fenced read-only SQL escape hatch (meta-tool: query). SELECT-only,
# allowlisted tables, mandatory LIMIT. Off by default in production until reviewed.
SQL_ESCAPE_ENABLED=true
SQL_ESCAPE_MAX_LIMIT=100

# Multi-step planner: LLM emits mode=single|chain plans (max 3 steps).
PLANNER_ENABLED=true
PLANNER_MAX_STEPS=3
# Baked-in plans for known demo questions (reliable hackathon chain demo).
PLANNER_DEMO_FALLBACK=true

LLM_TIMEOUT_SECONDS=30
LLM_MAX_ATTEMPTS=2

# Layer 1 cache: caches the question->tool-call translation only (no data), so a
# hit still queries the live DB. Auto-invalidated when the prompt/tools change.
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=86400
LLM_CACHE_MAX_ENTRIES=1024

# Backend Configuration
# Anchors relative dates ("last month", "today"). Olist data is rich through Aug 2018
# and near-empty after, so 2018-08-20 keeps demo queries lively. True data max is 2018-10-17.
REFERENCE_DATE=2018-08-20
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (for frontend) — comma-separated URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Phase 2 Hardening
# Global row cap: any query returning more than this is rejected at the query layer.
# Functions that legitimately return many rows (list_orders, top_products) already
# paginate/limit below this threshold.
MAX_RESULT_ROWS=200

# Simple in-memory rate limiter (requests per minute per IP). Set to 0 to disable.
# Not a replacement for a reverse-proxy limiter in production, but sufficient for
# single-tenant local/VPS deployments.
RATE_LIMIT_PER_MINUTE=30

# B1/B2 — App-state store (SQLite by default; Postgres DSN is a drop-in later).
# The running app connects with both this URL (read-write) and DB_URL (read-only
# Olist). Keep them on separate connections.
APP_DB_URL=sqlite:///app_state.db

# Deployment environment. Set to "production" to enforce strict boot checks
# (refuses the default SESSION_SECRET below). Use "development" for local work.
ENVIRONMENT=development

# Secure flag on auth cookies. MUST be true on any HTTPS/production deploy so the
# session cookie is never sent over plaintext. Explicit (not inferred from the
# bind address, since production usually still binds 0.0.0.0 behind a proxy).
COOKIE_SECURE=false

# B2 — Auth secret. MUST be overridden in production (boot refuses the default
# when ENVIRONMENT=production). Signs the session cookie token (itsdangerous
# wrapper around the auth_sessions row id). The CSRF token is a separate random
# value, not signed with this.
SESSION_SECRET=dev-only-change-me-in-production-please
SESSION_TTL_MINUTES=43200

# Stricter per-email+IP rate limit on /api/auth/* (brute-force defense).
# Format: "max_attempts/window_seconds". 0 means disabled.
AUTH_RATE_LIMIT=5/900

# Argon2id cost knobs (hashing/verify). Defaults are sane for production.
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=1

# Phase 3 — which schema config to load at startup. One of the keys
# registered in `backend/schemas/__init__.py::_BUILTIN` (currently: olist,
# shopify). Add a new schema by dropping a config module under
# `backend/schemas/<name>/` and registering the loader — then set
# SCHEMA_NAME=<name>. The orchestrator's prompt, validation layer, and
# SQL emitter all read from this config.
SCHEMA_NAME=olist

# Phase 2 hardening / trust
# Per-request audit log (append-only JSONL; stores a row-free result summary).
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.jsonl
# Keep false in prod so raw DB/internal errors never reach the client. Flip on in
# dev to see real exception text in API responses.
EXPOSE_INTERNAL_ERRORS=false
# Reject oversized questions before they reach the model/DB (HTTP 422).
MAX_QUESTION_LENGTH=2000
