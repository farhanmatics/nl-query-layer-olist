# Database Configuration
DB_URL=postgresql://nlq_readonly:changeme@localhost/olist
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT=5000

# Admin/superuser connection used ONLY by migrate.py (needs CREATE + CREATEROLE).
# The running app never uses this. Example: postgresql://postgres:pass@localhost/olist
MIGRATION_DB_URL=postgresql://localhost/olist

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b
# CPU inference latency swings widely; give it room and retry once on timeout/bad JSON
LLM_TIMEOUT_SECONDS=90
LLM_MAX_ATTEMPTS=2

# Layer 1 cache: caches the question->tool-call translation only (no data), so a
# hit still queries the live DB. Auto-invalidated when the prompt/tools change.
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=86400
LLM_CACHE_MAX_ENTRIES=1024

# Backend Configuration
# Anchors relative dates ("last month", "today"). Olist data is rich through Aug 2018
# and near-empty after, so 2018-08-20 keeps demo queries lively. True data max is 2018-10-17.
REFERENCE_DATE=2018-08-20
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (for frontend) — comma-separated URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Phase 2 Hardening
# Global row cap: any query returning more than this is rejected at the query layer.
# Functions that legitimately return many rows (list_orders, top_products) already
# paginate/limit below this threshold.
MAX_RESULT_ROWS=200

# Simple in-memory rate limiter (requests per minute per IP). Set to 0 to disable.
# Not a replacement for a reverse-proxy limiter in production, but sufficient for
# single-tenant local/VPS deployments.
RATE_LIMIT_PER_MINUTE=30

# Phase 2 hardening / trust
# Per-request audit log (append-only JSONL; stores a row-free result summary).
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.jsonl
# Keep false in prod so raw DB/internal errors never reach the client. Flip on in
# dev to see real exception text in API responses.
EXPOSE_INTERNAL_ERRORS=false
# Reject oversized questions before they reach the model/DB (HTTP 422).
MAX_QUESTION_LENGTH=2000
