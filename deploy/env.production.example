# Production .env snippet for https://nlquery.yydigi.top
# Copy relevant lines into /opt/nlq/.env on ECS.

DB_URL=postgresql://nlq_readonly:changeme@localhost:5533/olist
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.6-flash
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
META_TOOLS_ENABLED=true
SQL_ESCAPE_ENABLED=true
PLANNER_ENABLED=true
PLANNER_DEMO_FALLBACK=true

ENVIRONMENT=production
COOKIE_SECURE=true
SESSION_SECRET=replace-with-openssl-rand-hex-32
ALLOWED_ORIGINS=https://nlquery.yydigi.top

# Generate SESSION_SECRET on ECS:
#   openssl rand -hex 32
